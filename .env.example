DATABASE_URL=postgresql://temporal:temporal@localhost:5432/temporal
DBOS_SYSTEM_DATABASE_URL=
DBOS_SYSTEM_DATABASE_SCHEMA=dbos
DBOS_ADMIN_SERVER=false
DBOS_ADMIN_PORT=3001
DBOS_LOG_LEVEL=info
ORCHESTRATOR_PORT=3000
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,tauri://localhost
HONEYCOMB_API_TOKEN=
# Local development only. Leave false/empty for packaged desktop and releases.
HONEYCOMB_ALLOW_INSECURE_API=false

# Feishu/Lark bot integration. Feishu is only a display screen: the messages
# may start with @agent-name for humans, but DBOS/Postgres control the flow.
FEISHU_DEFAULT_CHAT_ID=
FEISHU_DRY_RUN=true

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
# Optional: ignore webhook events sent by the same bot if Feishu echoes them.
FEISHU_BOT_OPEN_ID=

# OpenClaw agent runtime. Default is mock so local DBOS/Postgres checks run
# without spending model calls. Set OPENCLAW_AGENT_MODE=real after verifying
# WSL OpenClaw/gateway and provider keys.
OPENCLAW_AGENT_MODE=mock
OPENCLAW_WSL_DISTRO=Ubuntu-24.04
OPENCLAW_CLI=/home/administrator/.npm-global/bin/openclaw
OPENCLAW_AGENT_TIMEOUT_SECONDS=600

# Optional M3 real planner. Default generator mode is mock. To call a real
# OpenAI-compatible chat-completions provider, set these without committing
# secrets.
M3_PLANNER_MODE=mock
M3_PLANNER_BASE_URL=
M3_PLANNER_MODEL=
M3_PLANNER_API_KEY=
M3_PLANNER_TEMPERATURE=0.2
M3_PLANNER_TIMEOUT_SECONDS=60

# Job/session lifecycle. Completed sessions are archived immediately but only
# become eligible for heavy intermediate cleanup after this many days.
SESSION_RETENTION_DAYS=30
