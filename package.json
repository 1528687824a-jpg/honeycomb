{
  "name": "honeycomb-orchestrator",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "build": "tsc",
    "db:migrate": "tsx packages/db/src/migrate.ts",
    "dev:api": "tsx apps/orchestrator-api/src/server.ts",
    "dev:worker": "tsx apps/dbos-worker/src/worker.ts",
    "dev:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "tryout:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-owner-tryout.ps1",
    "tryout:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-desktop-tryout.ps1",
    "tryout:shortcut": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-desktop-shortcut.ps1",
    "tryout:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-owner-tryout.ps1",
    "smoke:feishu-webhook": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-feishu-webhook.ps1",
    "smoke:docker-compose": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-docker-compose.ps1",
    "smoke:http-only": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-http-only-end-to-end.ps1",
    "smoke:feishu-public": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-public-feishu-webhook.ps1",
    "smoke:m2-recovery": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-m2-recovery.ps1",
    "smoke:m3-config": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-m3-config.ps1",
    "smoke:m3-real-planner": "tsx scripts/smoke-m3-real-planner.ts",
    "smoke:m3-real-provider": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-m3-real-provider.ps1",
    "smoke:cancel-job": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-cancel-job.ps1",
    "smoke:timeline-since": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-timeline-since.ps1",
    "smoke:workspace-registration": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-workspace-registration.ps1",
    "smoke:security-controls": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-security-controls.ps1",
    "smoke:secret-storage": "tsx scripts/smoke-secret-storage.ts",
    "smoke:runtime-usage-cost": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-runtime-usage-cost.ps1",
    "smoke:list-jobs": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-list-jobs.ps1",
    "smoke:experience-memory": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-experience-memory.ps1",
    "smoke:repair-cancelled-archives": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-repair-cancelled-archives.ps1",
    "smoke:openclaw-real": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-with-smoke-lock.ps1 dev-stack scripts/smoke-openclaw-real.ps1",
    "smoke:desktop-ui": "tsx scripts/smoke-desktop-ui.ts",
    "smoke:desktop-ui-prod": "tsx scripts/smoke-desktop-ui.ts --prod",
    "smoke:desktop-onboarding": "tsx scripts/smoke-desktop-ui.ts --prod --onboarding",
    "smoke:desktop-memory": "tsx scripts/smoke-desktop-ui.ts --prod --memory",
    "smoke:tauri-shell": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-tauri-shell.ps1",
    "m3:generate": "tsx scripts/generate-cluster-config.ts",
    "prepare:public-ingress": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-public-ingress-bundle.ps1",
    "maintenance:cleanup-sessions": "tsx scripts/cleanup-expired-sessions.ts",
    "maintenance:repair-cancelled-archives": "tsx scripts/repair-cancelled-archives.ts",
    "check:package-layout": "tsx scripts/check-package-layout.ts",
    "check:no-secrets": "tsx scripts/check-no-secrets.ts",
    "test:unit": "node --import tsx --test tests/*.test.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@dbos-inc/dbos-sdk": "^4.18.10",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
