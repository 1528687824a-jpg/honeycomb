{
  "name": "agent-openclaw-orchestrator",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "db:migrate": "tsx packages/db/src/migrate.ts",
    "dev:api": "tsx apps/orchestrator-api/src/server.ts",
    "dev:worker": "tsx apps/dbos-worker/src/worker.ts",
    "dev:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "smoke:feishu-webhook": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-feishu-webhook.ps1",
    "smoke:docker-compose": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-docker-compose.ps1",
    "smoke:http-only": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-http-only-end-to-end.ps1",
    "smoke:feishu-public": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-public-feishu-webhook.ps1",
    "smoke:m2-recovery": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-m2-recovery.ps1",
    "smoke:m3-config": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-m3-config.ps1",
    "smoke:m3-real-planner": "tsx scripts/smoke-m3-real-planner.ts",
    "smoke:m3-real-provider": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-m3-real-provider.ps1",
    "smoke:cancel-job": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-cancel-job.ps1",
    "smoke:openclaw-real": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-openclaw-real.ps1",
    "smoke:desktop-ui": "tsx scripts/smoke-desktop-ui.ts",
    "smoke:tauri-shell": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-tauri-shell.ps1",
    "m3:generate": "tsx scripts/generate-cluster-config.ts",
    "prepare:public-ingress": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-public-ingress-bundle.ps1",
    "maintenance:cleanup-sessions": "tsx scripts/cleanup-expired-sessions.ts",
    "check:no-secrets": "tsx scripts/check-no-secrets.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@dbos-inc/dbos-sdk": "^4.18.10",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
