{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent OpenClaw",
  "version": "0.1.0",
  "identifier": "art.tomorrow123.agent-openclaw",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agent OpenClaw",
        "width": 1180,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
