{
  "agents": {
    "list": [
      {
        "id": "main-agent",
        "default": true,
        "workspace": "openclaw-work/main",
        "agentDir": "openclaw-agents/main"
      },
      {
        "id": "research-agent",
        "workspace": "openclaw-work/research",
        "agentDir": "openclaw-agents/research",
        "model": {
          "primary": "deepseek-research/deepseek-v4-pro"
        }
      },
      {
        "id": "writer-agent",
        "workspace": "openclaw-work/writer",
        "agentDir": "openclaw-agents/writer",
        "model": {
          "primary": "deepseek-writer/deepseek-v4-pro"
        }
      },
      {
        "id": "image-agent",
        "workspace": "openclaw-work/image",
        "agentDir": "openclaw-agents/image",
        "model": {
          "primary": "deepseek-writer/deepseek-v4-pro"
        }
      },
      {
        "id": "video-agent",
        "workspace": "openclaw-work/video",
        "agentDir": "openclaw-agents/video",
        "model": {
          "primary": "deepseek-writer/deepseek-v4-pro"
        }
      },
      {
        "id": "test-agent",
        "workspace": "openclaw-work/test",
        "agentDir": "openclaw-agents/test",
        "model": {
          "primary": "zai/glm-5.1"
        }
      }
    ],
    "defaults": {
      "model": {
        "primary": "deepseek/deepseek-v4-flash"
      },
      "imageGenerationModel": {
        "primary": "openai/doubao-seedream-5-0-260128",
        "timeoutMs": 600000
      },
      "videoGenerationModel": {
        "primary": "byteplus/doubao-seedance-2-0-260128",
        "timeoutMs": 600000
      }
    }
  },
  "bindings": [
    {
      "agentId": "main-agent",
      "match": {
        "channel": "feishu"
      }
    }
  ],
  "tools": {
    "sessions": {
      "visibility": "tree"
    },
    "agentToAgent": {
      "enabled": true,
      "allow": [
        "main-agent",
        "research-agent",
        "writer-agent",
        "image-agent",
        "video-agent",
        "test-agent"
      ]
    }
  }
}
